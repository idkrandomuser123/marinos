#!/bin/bash
# MarinOS Installer
set -e
echo "v1.0"
echo "Thank you for using MarinOS!"
echo "Connect to the network using iwctl. If you havent this installation will fail!"
echo "Ethernet should work automatically!"
echo ""

# Network check
if ! ping -c 1 google.com &>/dev/null; then
    echo "No network connection detected, please connect first"
    exit 1
fi
echo "Network OK!"
echo ""

# Disk selection
echo "Available disks:"
lsblk -d -o NAME,SIZE,MODEL
echo ""
read -p "Enter disk to install to (e.g. sda, nvme0n1): " DISK
DISK="/dev/$DISK"

# Partitioning
echo ""
echo "Launch cfdisk, Create:"
echo "  1. EFI partition  (~512M, type: EFI System)"
echo "  2. Swap partition (~2-8G, type: Linux swap) [optional]"
echo "  3. Root partition (rest, type: Linux filesystem)"
echo ""
read -p "Press enter to launch cfdisk..."
cfdisk "$DISK"

# Detect partitions
echo ""
lsblk "$DISK"
echo ""
read -p "Enter EFI partition (e.g. sda1 or nvme0n1p1): " EFI_PART
read -p "Enter swap partition (leave blank to skip): " SWAP_PART
read -p "Enter root partition (e.g. sda2 or nvme0n1p2): " ROOT_PART
EFI_PART="/dev/$EFI_PART"
ROOT_PART="/dev/$ROOT_PART"

# Format
echo ""
echo "Formatting partitions..."
mkfs.fat -F32 "$EFI_PART"
mkfs.ext4 "$ROOT_PART"
if [ -n "$SWAP_PART" ]; then
    SWAP_PART="/dev/$SWAP_PART"
    mkswap "$SWAP_PART"
    swapon "$SWAP_PART"
fi

# Mount
echo "Mounting drives..."
mount "$ROOT_PART" /mnt
mkdir -p /mnt/boot/efi
mount "$EFI_PART" /mnt/boot/efi

# Install base system
echo ""
echo "Installing base system..."
while true; do
    if pacstrap /mnt base linux linux-firmware amd-ucode sudo yad nano networkmanager awww grub efibootmgr hyprland kitty wofi git base-devel sddm waybar ttf-jetbrains-mono-nerd firefox pipewire pipewire-pulse pipewire-alsa wireplumber; then
        break
    else
        echo "pacstrap failed, check your connection"
        read -p "Retry? (yes/no): " RETRY
        if [ "$RETRY" != "yes" ]; then
            echo "Exiting."
            exit 1
        fi
    fi
done

# fstab
echo "Generating fstab..."
genfstab -U /mnt >> /mnt/etc/fstab

# User setup
echo ""
read -p "Enter hostname (default: marinos-btw): " HOSTNAME
HOSTNAME=${HOSTNAME:-marinos-btw}
read -p "Enter username: " USERNAME
read -sp "Enter password for $USERNAME: " USERPASS
echo ""
read -sp "Enter root password: " ROOTPASS
echo ""
read -p "Enter timezone (e.g. Europe/Sarajevo): " TIMEZONE
TIMEZONE=${TIMEZONE:-Europe/Sarajevo}

# Chroot and configure
echo ""
echo "Configuring system..."
INSTALL_USER=$USERNAME
echo "$INSTALL_USER" > /tmp/marinos_user
arch-chroot /mnt /bin/bash <<EOF
# Timezone
ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime
hwclock --systohc

# Locale
echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf

# Hostname
echo "$HOSTNAME" > /etc/hostname
cat > /etc/hosts <<HOSTS
127.0.0.1   localhost
::1         localhost
127.0.1.1   $HOSTNAME.localdomain $HOSTNAME
HOSTS

# OS branding
cat > /etc/os-release <<OS
NAME="MarinOS"
PRETTY_NAME="MarinOS"
ID=marinos
ID_LIKE=arch
BUILD_ID=rolling
ANSI_COLOR="38;2;23;147;209"
OS

# Users
echo "Add users"
echo "root:$ROOTPASS" | chpasswd
useradd -m -G wheel -s /bin/bash $USERNAME
echo "$USERNAME:$USERPASS" | chpasswd

# Sudo
echo "Configure sudo"
echo "%wheel ALL=(ALL) ALL" >> /etc/sudoers

# Bootloader
echo "Install GRUB"
grub-install --target=x86_64-efi --efi-directory=/boot/efi --bootloader-id=MarinOS
grub-mkconfig -o /boot/grub/grub.cfg

# Enable services
systemctl enable NetworkManager
systemctl enable sddm

# Pipewire
echo "Configure pipewire"
mkdir -p /home/$USERNAME/.config/systemd/user/default.target.wants
ln -s /usr/lib/systemd/user/pipewire.service /home/$USERNAME/.config/systemd/user/default.target.wants/
ln -s /usr/lib/systemd/user/pipewire-pulse.service /home/$USERNAME/.config/systemd/user/default.target.wants/
ln -s /usr/lib/systemd/user/wireplumber.service /home/$USERNAME/.config/systemd/user/default.target.wants/

# mkinitcpio
mkinitcpio -P
EOF

echo "If chown fails then simply reboot dont worry"
# Copy configs
INSTALL_USER=$(cat /tmp/marinos_user)
echo "Copying configs for user: $INSTALL_USER"
cp -r /etc/skel/.config /mnt/home/$INSTALL_USER/
chown -R $INSTALL_USER:$INSTALL_USER /mnt/home/$INSTALL_USER/

# Finished
echo "If you see Arch Linux in GRUB then boot it, its most likely MarinOS"
echo "MarinOS has successfully installed!"
read -p "Press enter to reboot..."
umount -R /mnt
reboot
# thanks claude :) pookie
# -teo
